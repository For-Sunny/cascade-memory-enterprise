# ============================================
# CASCADE Memory System Configuration
# CIPS Corp - https://cipscorps.io
# ============================================

# Database storage path
# Default: ~/.cascade-memory/data
CASCADE_DB_PATH=./data

# Debug mode - exposes stack traces in errors
# Default: false
# WARNING: Never enable in production
DEBUG=false

# Log level: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Log format: json (machine) or text (human)
# Default: json
LOG_FORMAT=json

# Audit log file path (JSONL format)
# Leave empty to disable file logging
# Audit events still logged to stderr
CASCADE_AUDIT_LOG=

# ============================================
# ENTERPRISE CONFIGURATION
# ============================================
# For sub-millisecond performance, configure
# CASCADE with Speed Enhancement:
#
# CASCADE_DB_PATH=/path/to/high-speed/storage
#
# Speed Enhancement: $400 one-time
# Contact: glass@cipscorps.io
# Website: https://cipscorps.io
# ============================================
